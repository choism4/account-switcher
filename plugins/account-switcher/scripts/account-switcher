#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${HOME}/.claude/account-switcher"
ACCOUNTS_FILE="${STATE_DIR}/accounts.json"
CRED_FILE="${HOME}/.claude/.credentials.json"
CLAUDE_CONFIG_FILE="${HOME}/Library/Application Support/Claude/config.json"
KEYCHAIN_ACCOUNT_PREFIX="Claude Code account-switcher:"
KEYCHAIN_CONFIG_PREFIX="Claude Code account-switcher config:"
CLAUDE_KEYCHAIN_SERVICES=(
  "Claude Code-credentials"
  "Claude Code credentials"
  "Claude Code"
  "claude-code-credentials"
)
CREDENTIAL_JSON=""
CREDENTIAL_SOURCE=""

usage() {
  cat <<'EOF'
Usage:
  /account-switcher current
  /account-switcher ls
  /account-switcher register <name>
  /account-switcher unregister <name>
  /account-switcher use <name>
EOF
}

ensure_state() {
  mkdir -p "$STATE_DIR"
  if [[ ! -f "$ACCOUNTS_FILE" ]]; then
    printf '{"accounts":[]}\n' > "$ACCOUNTS_FILE"
  fi
}

current() {
  claude auth status --json | node -e '
let input = "";
process.stdin.on("data", chunk => input += chunk);
process.stdin.on("end", () => {
  const status = JSON.parse(input);
  if (!status.loggedIn) {
    console.log("Not logged in.");
    return;
  }
  console.log(`Logged in: ${status.email || "(unknown email)"}`);
  console.log(`Auth method: ${status.authMethod || "(unknown)"}`);
  console.log(`Provider: ${status.apiProvider || "(unknown)"}`);
  console.log(`Subscription: ${status.subscriptionType || "(unknown)"}`);
  if (status.orgName) console.log(`Org: ${status.orgName}`);
});
'
}

current_email() {
  claude auth status --json | node -e '
let input = "";
process.stdin.on("data", chunk => input += chunk);
process.stdin.on("end", () => {
  const status = JSON.parse(input);
  if (status.loggedIn && status.email) process.stdout.write(status.email);
});
'
}

is_macos() {
  [[ "$(uname -s)" == "Darwin" ]]
}

keychain_get() {
  local service="$1"
  security find-generic-password -s "$service" -w 2>/dev/null || true
}

keychain_set() {
  local service="$1"
  local password="$2"
  security add-generic-password \
    -a "${USER:-$(whoami)}" \
    -s "$service" \
    -l "$service" \
    -w "$password" \
    -U >/dev/null
}

keychain_delete() {
  local service="$1"
  security delete-generic-password -s "$service" >/dev/null 2>&1 || true
}

read_oauth_token_cache() {
  if [[ ! -f "$CLAUDE_CONFIG_FILE" ]]; then
    return 1
  fi

  node - "$CLAUDE_CONFIG_FILE" <<'NODE'
const fs = require("fs");
const file = process.argv[2];
try {
  const data = JSON.parse(fs.readFileSync(file, "utf8"));
  const tokenCache = data["oauth:tokenCache"];
  if (typeof tokenCache === "string" && tokenCache.length > 0) {
    process.stdout.write(tokenCache);
  }
} catch {
  process.exit(1);
}
NODE
}

restore_oauth_token_cache() {
  local token_cache="$1"
  mkdir -p "$(dirname "$CLAUDE_CONFIG_FILE")"
  node - "$CLAUDE_CONFIG_FILE" "$token_cache" <<'NODE'
const fs = require("fs");
const file = process.argv[2];
const tokenCache = process.argv[3];
let data = {};
try {
  if (fs.existsSync(file)) data = JSON.parse(fs.readFileSync(file, "utf8"));
} catch {
  data = {};
}
data["oauth:tokenCache"] = tokenCache;
fs.writeFileSync(file, JSON.stringify(data, null, 2) + "\n");
NODE
}

read_current_credentials() {
  CREDENTIAL_JSON=""
  CREDENTIAL_SOURCE=""

  if is_macos; then
    local service
    for service in "${CLAUDE_KEYCHAIN_SERVICES[@]}"; do
      CREDENTIAL_JSON="$(keychain_get "$service")"
      if [[ -n "$CREDENTIAL_JSON" ]]; then
        CREDENTIAL_SOURCE="$service"
        return 0
      fi
    done
  fi

  if [[ -f "$CRED_FILE" ]]; then
    CREDENTIAL_JSON="$(<"$CRED_FILE")"
    CREDENTIAL_SOURCE="file:$CRED_FILE"
    return 0
  fi

  return 1
}

read_account_credentials() {
  local service="$1"
  keychain_get "$service"
}

restore_current_credentials() {
  local source="$1"
  local credentials="$2"

  if [[ "$source" == file:* ]]; then
    local file="${source#file:}"
    mkdir -p "$(dirname "$file")"
    printf '%s\n' "$credentials" > "$file"
    return
  fi

  keychain_set "$source" "$credentials"
}

list_accounts() {
  ensure_state
  node - "$ACCOUNTS_FILE" <<'NODE'
const fs = require("fs");
const file = process.argv[2];
const data = JSON.parse(fs.readFileSync(file, "utf8"));
if (!data.accounts.length) {
  console.log("No accounts registered.");
  process.exit(0);
}
for (const account of data.accounts) {
  const hint = account.email_hint ? ` (${account.email_hint})` : "";
  console.log(`- ${account.name}${hint}`);
}
NODE
}

register_account() {
  local name="${1:-}"
  local unexpected="${2:-}"
  if [[ -z "$name" ]]; then
    usage
    exit 2
  fi
  if [[ -n "$unexpected" ]]; then
    echo "register accepts only <name>."
    usage
    exit 2
  fi
  if [[ ! "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]]; then
    echo "Invalid account name. Use letters, numbers, dots, underscores, or hyphens."
    exit 2
  fi

  if ! is_macos; then
    echo "Keychain account switching is currently supported only on macOS."
    exit 1
  fi

  if ! read_current_credentials; then
    echo "No Claude Code credentials found in macOS Keychain or $CRED_FILE."
    echo "Make sure Claude Code is installed and you are logged in (run: claude auth status)."
    exit 1
  fi

  local credential_service="${KEYCHAIN_ACCOUNT_PREFIX} ${name}"
  local config_service="${KEYCHAIN_CONFIG_PREFIX} ${name}"
  keychain_set "$credential_service" "$CREDENTIAL_JSON"
  local oauth_token_cache
  oauth_token_cache="$(read_oauth_token_cache || true)"
  if [[ -n "$oauth_token_cache" ]]; then
    keychain_set "$config_service" "$oauth_token_cache"
  else
    config_service=""
  fi

  ensure_state
  node - "$ACCOUNTS_FILE" "$name" "$credential_service" "$CREDENTIAL_SOURCE" "$config_service" <<'NODE'
const fs = require("fs");
const [file, name, credentialService, sourceService, configService] = process.argv.slice(2);
const data = JSON.parse(fs.readFileSync(file, "utf8"));
const existing = data.accounts.find(account => account.name === name);
if (existing) {
  delete existing.email_hint;
  existing.credential_service = credentialService;
  existing.source_service = sourceService;
  if (configService) existing.config_service = configService;
  else delete existing.config_service;
  existing.updated_at = new Date().toISOString();
  fs.writeFileSync(file, JSON.stringify(data, null, 2) + "\n");
  console.log(`Updated account: ${name}`);
  process.exit(0);
}
const account = {
  name,
  credential_service: credentialService,
  source_service: sourceService,
  registered_at: new Date().toISOString()
};
if (configService) account.config_service = configService;
data.accounts.push(account);
fs.writeFileSync(file, JSON.stringify(data, null, 2) + "\n");
console.log(`Registered account: ${name}`);
NODE
}

unregister_account() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    usage
    exit 2
  fi

  ensure_state
  local credential_service
  local config_service
  local services
  services="$(node - "$ACCOUNTS_FILE" "$name" <<'NODE'
const fs = require("fs");
const [file, name] = process.argv.slice(2);
const data = JSON.parse(fs.readFileSync(file, "utf8"));
const account = data.accounts.find(item => item.name === name);
if (account) {
  process.stdout.write(JSON.stringify({
    credential_service: account.credential_service || "",
    config_service: account.config_service || ""
  }));
}
NODE
)"
  if [[ -n "$services" ]]; then
    credential_service="$(printf '%s' "$services" | node -e 'const fs=require("fs"); const data=JSON.parse(fs.readFileSync(0,"utf8")); process.stdout.write(data.credential_service);')"
    config_service="$(printf '%s' "$services" | node -e 'const fs=require("fs"); const data=JSON.parse(fs.readFileSync(0,"utf8")); process.stdout.write(data.config_service);')"
  else
    credential_service=""
    config_service=""
  fi

  node - "$ACCOUNTS_FILE" "$name" <<'NODE'
const fs = require("fs");
const [file, name] = process.argv.slice(2);
const data = JSON.parse(fs.readFileSync(file, "utf8"));
const before = data.accounts.length;
data.accounts = data.accounts.filter(account => account.name !== name);
fs.writeFileSync(file, JSON.stringify(data, null, 2) + "\n");
if (data.accounts.length === before) {
  console.log(`No such account: ${name}`);
} else {
  console.log(`Unregistered account: ${name}`);
}
NODE

  if [[ -n "$credential_service" ]] && is_macos; then
    keychain_delete "$credential_service"
  fi
  if [[ -n "$config_service" ]] && is_macos; then
    keychain_delete "$config_service"
  fi
}

use_account() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    usage
    exit 2
  fi

  ensure_state
  local account_info
  account_info="$(node - "$ACCOUNTS_FILE" "$name" <<'NODE'
const fs = require("fs");
const [file, name] = process.argv.slice(2);
const data = JSON.parse(fs.readFileSync(file, "utf8"));
const account = data.accounts.find(item => item.name === name);
if (!account) {
  console.log(`No such account: ${name}`);
  process.exit(2);
}
if (!account.credential_service) {
  console.log(`Account has no saved credentials: ${name}`);
  process.exit(2);
}
console.log(JSON.stringify({
  name: account.name,
  email_hint: account.email_hint || "",
  credential_service: account.credential_service,
  source_service: account.source_service || "Claude Code-credentials",
  config_service: account.config_service || ""
}));
NODE
)"

  local credential_service
  local source_service
  local email_hint
  local config_service
  credential_service="$(printf '%s' "$account_info" | node -e 'const fs=require("fs"); const data=JSON.parse(fs.readFileSync(0,"utf8")); process.stdout.write(data.credential_service);')"
  source_service="$(printf '%s' "$account_info" | node -e 'const fs=require("fs"); const data=JSON.parse(fs.readFileSync(0,"utf8")); process.stdout.write(data.source_service);')"
  email_hint="$(printf '%s' "$account_info" | node -e 'const fs=require("fs"); const data=JSON.parse(fs.readFileSync(0,"utf8")); process.stdout.write(data.email_hint);')"
  config_service="$(printf '%s' "$account_info" | node -e 'const fs=require("fs"); const data=JSON.parse(fs.readFileSync(0,"utf8")); process.stdout.write(data.config_service);')"

  local credentials
  credentials="$(read_account_credentials "$credential_service")"
  if [[ -z "$credentials" ]]; then
    echo "No saved credentials found in macOS Keychain for account: $name"
    exit 1
  fi

  restore_current_credentials "$source_service" "$credentials"
  if [[ -n "$config_service" ]]; then
    local oauth_token_cache
    oauth_token_cache="$(keychain_get "$config_service")"
    if [[ -n "$oauth_token_cache" ]]; then
      restore_oauth_token_cache "$oauth_token_cache"
    fi
  fi
  echo "Switched to account: $name${email_hint:+ ($email_hint)}"
}

cmd="${1:-}"
shift || true

case "$cmd" in
  current)
    current
    ;;
  ls|list)
    list_accounts
    ;;
  register)
    register_account "$@"
    ;;
  unregister|remove|rm)
    unregister_account "$@"
    ;;
  use|switch)
    use_account "$@"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "Unknown command: $cmd"
    usage
    exit 2
    ;;
esac
